---
import { actions, isInputError } from "astro:actions";

interface Props {
    pet: {
        documentId: string;
        name: string;
        imageUrl: string;
    };
}

const { pet } = Astro.props;
const result = Astro.getActionResult(actions.createAdoptionRequest);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<div class="bg-white rounded-2xl shadow-xl overflow-hidden max-w-4xl mx-auto">
    {/* Mensaje de solicitud enviada */}
    {
        result?.data?.success === true && (
            <div
                class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4"
                role="alert"
            >
                <p class="font-bold">¡Solicitud de contacto enviada correctamente!</p>
                <p>{result.data.message}</p>
            </div>
        )
    }
    {
        result?.data?.success === false && (
            <div
                class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4"
                role="alert"
            >
                <p class="font-bold">La solicitud de contacto no pudo completarse</p>
                <p>{result.data.message || "Por favor, inténtalo nuevamente."}</p>
            </div>
        )
    }

    {/* Mensaje de error */}
    {
        result?.error && (
            <div
                class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4"
                role="alert"
            >
                <p class="font-bold">Error al enviar la solicitud de contacto</p>
                <p>
                    {isInputError(result.error)
                        ? "Por favor revisa los campos del formulario."
                        : result.error.message ||
                          "Ocurrió un error inesperado. Intenta nuevamente."}
                </p>
            </div>
        )
    }

    <div class="grid md:grid-cols-2">
        {/* Columna imagen */}
        <div class="relative">
            <img
                src={pet.imageUrl}
                alt={pet.name}
                class="w-full h-full object-cover"
            />
            <div
                class="absolute inset-0 bg-gradient-to-t from-amber-900/90 to-transparent flex items-end p-8"
            >
                <div class="text-white">
                    <p class="text-lg italic mb-2">
                        "¡Hola! Soy {pet.name} y estoy buscando una familia que me
                        brinde mucho amor..."
                    </p>
                    <p class="text-amber-200 text-sm">
                        Cada adopción no solo cambia la vida de una mascota,
                        sino que también llena de alegría y amor incondicional
                        tu hogar.
                    </p>
                </div>
            </div>
        </div>

        {/* Columna formulario */}
        <div class="p-8 bg-gradient-to-br from-amber-50 to-white">
            <h3
                class="text-2xl font-bold text-amber-900 mb-6 border-b pb-2 border-amber-200"
            >
                Solicitud de contacto para iniciar la adopción de {pet.name}
            </h3>

            {
                !result?.data?.success ? (
                    <form
                        id="adoption-form"
                        class="space-y-6"
                        method="POST"
                        action={actions.createAdoptionRequest}
                    >
                        <input type="hidden" name="pet" value={pet.documentId} />
                        <input type="hidden" name="petName" value={pet.name} />
                        <input type="hidden" name="petImage" value={pet.imageUrl} />

                        <div class="space-y-4">
                            {/* Nombre */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    Nombre completo
                                </label>
                                <input
                                    type="text"
                                    name="name"
                                    required
                                    class:list={[
                                        "w-full rounded-lg border shadow-sm py-2.5 px-3 transition-all duration-200",
                                        inputErrors.name
                                            ? "border-red-300 focus:border-red-500 focus:ring-red-500"
                                            : "border-amber-200 focus:border-amber-500 focus:ring-amber-500",
                                    ]}
                                    placeholder="Tu nombre completo"
                                />
                                {inputErrors.name && (
                                    <p class="text-red-500 text-xs mt-1">
                                        {inputErrors.name.join(", ")}
                                    </p>
                                )}
                            </div>

                            {/* Email */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    Email
                                </label>
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-amber-500">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-4 w-4"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                            />
                                        </svg>
                                    </span>
                                    <input
                                        type="email"
                                        name="email"
                                        required
                                        class:list={[
                                            "w-full rounded-lg border shadow-sm py-2.5 pl-10 pr-3 transition-all duration-200",
                                            inputErrors.email
                                                ? "border-red-300 focus:border-red-500 focus:ring-red-500"
                                                : "border-amber-200 focus:border-amber-500 focus:ring-amber-500",
                                        ]}
                                        placeholder="ejemplo@email.com"
                                    />
                                    {inputErrors.email && (
                                        <p class="text-red-500 text-xs mt-1">
                                            {inputErrors.email.join(", ")}
                                        </p>
                                    )}
                                </div>
                            </div>

                            {/* Teléfono */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    Teléfono
                                </label>
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-amber-500">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-4 w-4"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                            />
                                        </svg>
                                    </span>
                                    <input
                                        type="tel"
                                        name="phone"
                                        required
                                        class:list={[
                                            "w-full rounded-lg border shadow-sm py-2.5 pl-10 pr-3 transition-all duration-200",
                                            inputErrors.phone
                                                ? "border-red-300 focus:border-red-500 focus:ring-red-500"
                                                : "border-amber-200 focus:border-amber-500 focus:ring-amber-500",
                                        ]}
                                        placeholder="000-000-0000"
                                    />
                                    {inputErrors.phone && (
                                        <p class="text-red-500 text-xs mt-1">
                                            {inputErrors.phone.join(", ")}
                                        </p>
                                    )}
                                </div>
                            </div>

                            {/* Dirección */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    Dirección
                                </label>
                                <input
                                    type="text"
                                    name="address"
                                    required
                                    class:list={[
                                        "w-full rounded-lg border shadow-sm py-2.5 px-3 transition-all duration-200",
                                        inputErrors.address
                                            ? "border-red-300 focus:border-red-500 focus:ring-red-500"
                                            : "border-amber-200 focus:border-amber-500 focus:ring-amber-500",
                                    ]}
                                    placeholder="Tu dirección completa"
                                />
                                {inputErrors.address && (
                                    <p class="text-red-500 text-xs mt-1">
                                        {inputErrors.address.join(", ")}
                                    </p>
                                )}
                            </div>

                            {/* Mascotas actuales */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    ¿Tienes otras mascotas en casa?
                                </label>
                                <div class="relative">
                                    <select
                                        name="hasPets"
                                        class="appearance-none w-full rounded-lg border border-amber-200 shadow-sm py-2.5 px-3 pr-8 bg-white transition-all duration-200 cursor-pointer"
                                    >
                                        <option value="no">
                                            No, sería mi primera mascota
                                        </option>
                                        <option value="perro">
                                            Sí, tengo perro(s)
                                        </option>
                                        <option value="gato">
                                            Sí, tengo gato(s)
                                        </option>
                                        <option value="ambos">
                                            Sí, tengo perros y gatos
                                        </option>
                                        <option value="otros">
                                            Sí, tengo otras mascotas
                                        </option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-amber-600">
                                        <svg
                                            class="h-5 w-5"
                                            xmlns="http://www.w3.org/2000/svg"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                    </div>
                                </div>
                            </div>

                            {/* Razón para solicitar contacto */}
                            <div class="group">
                                <label class="block text-sm font-medium text-amber-800 mb-1">
                                    ¿Por qué deseas que te contactemos para iniciar la adopción de {pet.name}?
                                </label>
                                <textarea
                                    rows="3"
                                    name="adoptionReason"
                                    class:list={[
                                        "w-full rounded-lg border shadow-sm py-2.5 px-3 transition-all duration-200 resize-none",
                                        inputErrors.adoptionReason
                                            ? "border-red-300 focus:border-red-500 focus:ring-red-500"
                                            : "border-amber-200 focus:border-amber-500 focus:ring-amber-500",
                                    ]}
                                    placeholder={`Cuéntanos por qué ${pet.name} sería perfecto para tu hogar y cómo te podemos contactar...`}
                                />
                                {inputErrors.adoptionReason && (
                                    <p class="text-red-500 text-xs mt-1">
                                        {inputErrors.adoptionReason.join(", ")}
                                    </p>
                                )}
                            </div>
                        </div>

                        <div class="pt-4">
                            <button
                                id="open-modal-btn"
                                type="button"
                                class="w-full bg-gradient-to-r from-amber-600 to-amber-700 text-white py-3 px-6 rounded-xl font-semibold hover:from-amber-700 hover:to-amber-800 transition-all duration-300 shadow-md hover:shadow-lg flex items-center justify-center gap-2"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                >
                                    <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" />
                                </svg>
                                Enviar solicitud de contacto
                            </button>
                        </div>
                    </form>
                ) : (
                    <div class="space-y-4 text-center">
                        <div class="flex justify-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-24 w-24 text-green-500"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                        </div>
                        <h4 class="text-xl font-semibold text-gray-800">
                            ¡Tu solicitud de contacto ha sido enviada!
                        </h4>
                        <p class="text-gray-600">
                            Nos pondremos en contacto contigo pronto para continuar
                            con los pasos del proceso de adopción.
                        </p>
                        <div class="pt-4">
                            <a
                                href="/adopta"
                                class="inline-block bg-amber-100 text-amber-700 hover:bg-amber-200 py-2 px-4 rounded-lg transition-colors"
                            >
                                Ver más mascotas en adopción
                            </a>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</div>

{/* Modal de confirmación del proceso de adopción */}
<div
    id="adoption-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
>
    {/* Backdrop */}
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-black/60 backdrop-blur-sm"
    ></div>

    {/* Panel */}
    <div class="relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
        {/* Banner de advertencia */}
        <div class="bg-amber-500 rounded-t-2xl px-6 py-4 flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
            </svg>
            <div>
                <h2 id="modal-title" class="text-white font-bold text-lg leading-tight">
                    Antes de continuar, ten en cuenta...
                </h2>
                <p class="text-amber-100 text-sm mt-1">
                    Enviar este formulario <strong class="text-white">NO significa que la mascota ya es tuya.</strong>
                </p>
            </div>
        </div>

        {/* Cuerpo */}
        <div class="px-6 py-5">
            <p class="text-gray-700 mb-5">
                Este formulario es una <strong>solicitud de contacto</strong>. Al enviarlo, nuestro equipo se comunicará contigo para iniciar un proceso de evaluación. La adopción se completa únicamente después de seguir todos los pasos:
            </p>

            <ol class="space-y-4">
                <li class="flex gap-3 items-start">
                    <span class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-800 font-bold text-sm">1</span>
                    <div>
                        <p class="font-semibold text-amber-900 text-sm">Revisión inicial</p>
                        <p class="text-gray-600 text-sm">Validamos tu información y te contactamos en máximo 48 horas.</p>
                    </div>
                </li>
                <li class="flex gap-3 items-start">
                    <span class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-800 font-bold text-sm">2</span>
                    <div>
                        <p class="font-semibold text-amber-900 text-sm">Entrevista y visita al hogar</p>
                        <p class="text-gray-600 text-sm">Evaluamos que el ambiente sea adecuado para la mascota.</p>
                    </div>
                </li>
                <li class="flex gap-3 items-start">
                    <span class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-800 font-bold text-sm">3</span>
                    <div>
                        <p class="font-semibold text-amber-900 text-sm">Período de adaptación</p>
                        <p class="text-gray-600 text-sm">Si todo avanza bien, inicias un período de convivencia mientras se completan los trámites.</p>
                    </div>
                </li>
                <li class="flex gap-3 items-start">
                    <span class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-800 font-bold text-sm">4</span>
                    <div>
                        <p class="font-semibold text-amber-900 text-sm">Adopción oficial</p>
                        <p class="text-gray-600 text-sm">Firmamos el contrato de adopción y la mascota pasa oficialmente a tu familia.</p>
                    </div>
                </li>
            </ol>
        </div>

        {/* Acciones */}
        <div class="px-6 pb-6 flex flex-col sm:flex-row gap-3 justify-end">
            <button
                id="modal-cancel-btn"
                type="button"
                class="px-5 py-2.5 rounded-xl border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors"
            >
                Cancelar
            </button>
            <button
                id="modal-confirm-btn"
                type="button"
                class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-amber-600 to-amber-700 text-white font-semibold hover:from-amber-700 hover:to-amber-800 transition-all shadow-md hover:shadow-lg flex items-center gap-2"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                Entiendo, enviar mi solicitud
            </button>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById('adoption-modal') as HTMLElement;
    const form = document.getElementById('adoption-form') as HTMLFormElement;
    const openBtn = document.getElementById('open-modal-btn') as HTMLButtonElement;
    const cancelBtn = document.getElementById('modal-cancel-btn') as HTMLButtonElement;
    const confirmBtn = document.getElementById('modal-confirm-btn') as HTMLButtonElement;
    const backdrop = document.getElementById('modal-backdrop') as HTMLElement;

    function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', () => {
        if (!form.reportValidity()) return;
        openModal();
    });

    cancelBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    confirmBtn?.addEventListener('click', () => {
        closeModal();
        form.requestSubmit();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModal();
        }
    });
</script>
