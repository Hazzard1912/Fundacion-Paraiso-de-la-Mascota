---
import { getHeroData, getLastAdoptedPet } from "../actions/cms.actions";
import { Image } from "astro:assets";


import heroBg from "../assets/images/stock/hero-bg.jpeg";

// Obtener datos del hero desde Strapi
let heroData = null;
let error = null;

try {
    const result = await Astro.callAction(getHeroData, {});
    if (result.error) {
        console.error("Error fetching hero data:", result.error);
        error = result.error;
    } else if (result.data) {
        heroData = result.data;
    }
} catch (e) {
    console.error("Exception fetching hero data:", e);
    error = e;
}

// Datos por defecto en caso de error

const defaultData = {
    title: "Dale una Segunda Oportunidad",
    subtitle: "Cada mascota merece un hogar lleno de amor. Tu pequeño gesto puede cambiar una vida para siempre.",
    backgroundImage: heroBg,
    alternativeText: "Imagen de fondo del hero",
};

// Usar datos de Strapi si están disponibles, sino usar datos por defecto
const finalData = (heroData && heroData.success && heroData.data) ? heroData.data : defaultData;

// Última mascota adoptada (badge de prueba social)
let lastAdopted: { name: string; adoptionDate: string | null } | null = null;
try {
    const r = await Astro.callAction(getLastAdoptedPet, {});
    if (r.data?.success && r.data?.data) lastAdopted = r.data.data;
} catch {}

function daysAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const days = Math.floor(diff / 86_400_000);
    if (days === 0) return "hoy";
    if (days === 1) return "hace 1 día";
    return `hace ${days} días`;
}
---

<section
    class="relative min-h-screen bg-gradient-to-b from-neutral-900/80 to-neutral-900/20"
    id="hero"
>
    <!-- Background Image -->
    <div class="absolute inset-0 -z-10">
        <Image
            src={finalData.backgroundImage}
            alt={finalData.alternativeText || "Hero background"}
            width={1920}
            height={1080}
            class="w-full h-full object-cover"
            loading="eager"
        />
    </div>

    <!-- Content Container -->
    <div
        class="container mx-auto px-4 h-screen flex flex-col items-center justify-center text-white"
    >
        <!-- Main Content -->
        <div class="max-w-4xl text-center space-y-6 md:space-y-8">
            <h1
                class="text-3xl sm:text-4xl md:text-7xl font-bold leading-tight animate-fade-in"
            >
                {finalData.title.split(' ').slice(0, -1).join(' ')}
                <span class="text-amber-400">{finalData.title.split(' ').slice(-1)[0]}</span>
            </h1>

            <p class="text-lg sm:text-xl md:text-2xl text-gray-200 max-w-2xl mx-auto">
                {finalData.subtitle}
            </p>

            <!-- Action Buttons -->
            <div class="flex flex-wrap justify-center gap-3 sm:gap-4 mt-6 md:mt-8">
                <a
                    href="/adopta"
                    class="px-6 sm:px-8 py-3 sm:py-4 bg-amber-500 hover:bg-amber-600 rounded-full font-semibold text-base sm:text-lg transition-all transform hover:scale-105"
                >
                    Adopta Ahora
                </a>
                <a
                    href="/ayudanos#donaciones"
                    class="px-6 sm:px-8 py-3 sm:py-4 bg-white/10 backdrop-blur hover:bg-white/20 rounded-full font-semibold text-base sm:text-lg transition-all"
                >
                    Haz una Donación
                </a>
            </div>

            <!-- Social proof badge: última adopción -->
            {lastAdopted && (
                <div class="mt-6 flex justify-center">
                    <a
                        href="/adopta"
                        class="group inline-flex items-center gap-3 bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 text-white px-5 py-3 rounded-2xl transition-all duration-300 text-sm font-medium"
                    >
                        <span class="relative flex h-2.5 w-2.5 flex-shrink-0">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-400"></span>
                        </span>
                        <span>
                            <strong>{lastAdopted.name}</strong> encontró un hogar
                            {lastAdopted.adoptionDate && ` · ${daysAgo(lastAdopted.adoptionDate)}`}
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            )}

            <!-- Stats -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 md:gap-8 mt-8 md:mt-12 max-w-lg mx-auto">
                <div class="text-center">
                    <span class="block text-2xl sm:text-3xl md:text-4xl font-bold text-amber-400"
                        >2000+</span
                    >
                    <span class="text-gray-300 text-xs sm:text-sm md:text-base">Mascotas Adoptadas</span>
                </div>
                <div class="text-center">
                    <span class="block text-2xl sm:text-3xl md:text-4xl font-bold text-amber-400"
                        >22</span
                    >
                    <span class="text-gray-300 text-xs sm:text-sm md:text-base">Años de Experiencia</span>
                </div>
            </div>
        </div>
    </div>
</section>
