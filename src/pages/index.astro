---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Mision from "../components/Mision.astro";
import FeaturedPets from "../components/FeaturedPets.astro";
import LatestAdoptions from "../components/LatestAdoptions.astro";
import CallToAction from "../components/CallToAction.astro";
import Carousel from "../components/Carousel.astro";
import Historia from "../components/Historia.astro";
import FAQ from "../components/FAQ.astro";
import UltimaNoticia from "../components/UltimaNoticia.astro";
import { getHeroData, getLastAdoptedPet, getSlidesData, getMisionData, getHistoriaData, getFAQData } from "../actions/cms.actions";
import { actions } from "astro:actions";

// Paralelizar todas las llamadas a Strapi
const [heroResult, lastAdoptedResult, slidesResult, noticiasResult, misionResult, historiaResult, faqResult] = await Promise.all([
	Astro.callAction(getHeroData, {}),
	Astro.callAction(getLastAdoptedPet, {}),
	Astro.callAction(getSlidesData, {}),
	Astro.callAction(actions.getNoticiasData, {}),
	Astro.callAction(getMisionData, {}),
	Astro.callAction(getHistoriaData, {}),
	Astro.callAction(getFAQData, {}),
]);
---

<Layout 
	title="Fundación Paraíso de la Mascota Cali - Adopción Responsable de Perros y Gatos"
	description="Fundación Paraíso de la Mascota Cali - Más de 20 años rescatando, rehabilitando y buscando hogares responsables para perros y gatos en situación de vulnerabilidad. ¡Adopta y cambia una vida!"
	keywords="adopción mascotas Cali, perros gatos adopción, fundación animal Colombia, rescate mascotas, adopción responsable, mascotas abandonadas Cali, refugio animal"
	ogTitle="Fundación Paraíso de la Mascota Cali - Adopción Responsable"
	ogDescription="Más de 20 años rescatando y rehabilitando mascotas en Cali. ¡Adopta y cambia una vida para siempre!"
>
	<Hero heroData={heroResult.data} lastAdoptedData={lastAdoptedResult.data} />
	<Carousel slidesData={slidesResult.data} />
	<UltimaNoticia noticiasData={noticiasResult.data} />
	<Mision misionData={misionResult.data} />
	<Historia historiaData={historiaResult.data} />
	<FeaturedPets server:defer />
	<LatestAdoptions server:defer />
	<CallToAction />
	<FAQ faqData={faqResult.data} />
</Layout>
